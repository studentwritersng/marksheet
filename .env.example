# Database (Postgres)
DATABASE_URL="postgresql://user:password@host:port/db"

# Auth — generate a random 64-char hex string
AUTH_SECRET="change-me-to-a-random-secret"

# AI Gateway (PRD 14)
AI_BASE_URL="https://openrouter.ai/api/v1"
AI_API_KEY=""
AI_DEFAULT_MODEL="anthropic/claude-sonnet-4.5"
AI_MOCK="true"

# SMTP (email) — uncomment to enable real email sending
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@marksheet.dev"
