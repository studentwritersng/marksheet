// Marksheet — Nigerian Secondary School Syllabus & Examination Platform
// Schema covers foundational modules: PRD 01 (School/Session/Term/Class),
// PRD 02 (Staff/Roles/Assignments), PRD 03 (Students/Guardians),
// plus cross-cutting scaffolding: multi-tenancy (school_id), audit log (PRD 11),
// and AI provider config (PRD 14). Later PRDs extend this incrementally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// PRD 01: School, Session & Term Management
// ---------------------------------------------------------------------------

model School {
  id                 String     @id @default(cuid())
  name               String
  address            String?
  logo               String?
  signature          String? // principal/rector signature image URL
  stamp              String? // school stamp image URL
  phone              String?
  email              String?
  motto              String?
  letterheadSettings Json?
  // Configurable grading scale (e.g. A1-F9 bands). Stored as ordered JSON bands.
  gradingScale       Json?
  // Admission number format template, e.g. "SCH/{year}/{seq:4}"
  admissionFormat    String?
  // Shortcode for auto-generating student IDs, e.g. "TDC" → "TDC00123"
  shortcode          String?  @unique
  // Auto-incrementing counter for student numbers
  studentSequence    Int      @default(0)
  // Maintenance mode — when true, non-admin users see a maintenance page
  maintenanceMode    Boolean  @default(false)
  // Suspended by platform owner — when true, all school users are blocked
  suspended          Boolean  @default(false)
  // Fee gating configuration (PRD 12 §3.2)
  feeGateExams       Boolean  @default(false) // block exam access if fee not cleared
  feeGateResults     Boolean  @default(false) // block result release if fee not cleared
  // Pricing stage for this school
  stageId            String?
  stage              PlanStage? @relation(fields: [stageId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sessions             Session[]
  subjects             Subject[]
  staff                Staff[]
  students             Student[]
  users                User[]
  auditLogs            AuditLog[]
  syllabi              Syllabus[]
  lessonNotes          LessonNote[]
  questions            Question[]
  exams                Exam[]
  assessmentWeightings AssessmentWeighting[]
  assessmentTypes      AssessmentType[]
  reportCardTemplates  ReportCardTemplate[]
  timetablePeriods     TimetablePeriod[]
  timetableEntries     TimetableEntry[]
  classSubjects        ClassSubject[]
  announcements        Announcement[]
  licenses             SchoolLicense[]
  payments             Payment[]
  tickets              Ticket[]
  consentRecords       ConsentRecord[]
  schoolAddons         SchoolAddon[]
  subjectRequirements  SubjectTimetableRequirement[]
  staffAvailability    StaffAvailability[]
  timetableTemplates   TimetableTemplate[]
  timetableRules       SchoolTimetableRule[]
  addonTimetables      AddonTimetable[]
  taughtTopics         TaughtTopic[]

  @@map("schools")
}

enum SessionStatus {
  upcoming
  active
  closed
}

model Session {
  id        String        @id @default(cuid())
  schoolId  String
  label     String // e.g. "2025/2026"
  isCurrent Boolean       @default(false)
  status    SessionStatus @default(upcoming)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms   Term[]
  classes Class[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@map("sessions")
}

enum TermName {
  First
  Second
  Third
}

model Term {
  id        String    @id @default(cuid())
  sessionId String
  name      TermName
  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  session        Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  lessonNotes    LessonNote[]
  exams          Exam[]
  subjectResults SubjectResult[]
  termResults    TermResult[]

  @@unique([sessionId, name])
  @@index([sessionId])
  @@map("terms")
}

model Class {
  id         String   @id @default(cuid())
  schoolId   String
  sessionId  String
  name       String // auto-generated: level + section (e.g. "JSS1" or "JSS1A")
  level      String // JSS1 / JSS2 / JSS3 / SSS1 / SSS2 / SSS3
  section    String   @default("") // optional arm: "A", "B", "C"... "" means single-section
  department String   @default("") // SSS only: "science" / "art" / "commercial" / ""
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session          Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignments      Assignment[]
  students         Student[]
  promotionsFrom   PromotionRecord[] @relation("PromotionFromClass")
  promotionsTo     PromotionRecord[] @relation("PromotionToClass")
  lessonNotes      LessonNote[]
  exams            Exam[]
  examClasses      ExamClass[]
  timetableEntries     TimetableEntry[]
  classSubjects        ClassSubject[]
  subjectRequirements  SubjectTimetableRequirement[]
  addonTimetableEntries AddonTimetableEntry[]
  taughtTopics          TaughtTopic[]

  @@unique([sessionId, level, section, department])
  @@index([schoolId])
  @@index([sessionId])
  @@map("classes")
}

model PromotionRecord {
  id            String   @id @default(cuid())
  schoolId      String
  fromClassId   String
  toClassId     String? // null when outcome is withdrawal
  sessionFromId String
  sessionToId   String?
  studentIds    String[] // admission-time snapshot of promoted students
  performedBy   String // Staff id
  performedAt   DateTime @default(now())
  notes         String?

  fromClass Class  @relation("PromotionFromClass", fields: [fromClassId], references: [id])
  toClass   Class? @relation("PromotionToClass", fields: [toClassId], references: [id])

  @@index([schoolId])
  @@index([fromClassId])
  @@map("promotion_records")
}

// ---------------------------------------------------------------------------
// PRD 02: Staff, Roles & Permissions
// ---------------------------------------------------------------------------

model Staff {
  id            String   @id @default(cuid())
  schoolId      String
  fullName      String
  email         String
  phone         String?
  image         String? // profile photo URL
  signature     String? // signature image URL for report cards
  bioData       Json?
  accountStatus String   @default("active") // active / suspended
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments      Assignment[]
  user             User?
  timetableEntries TimetableEntry[]
  staffAvailabilities    StaffAvailability[]
  addonTimetableEntries  AddonTimetableEntry[]
  taughtTopics           TaughtTopic[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("staff")
}

// ---------------------------------------------------------------------------
// ClassSubject — links subjects to classes for department handling
// ---------------------------------------------------------------------------

model ClassSubject {
  id         String @id @default(cuid())
  schoolId   String
  classId    String
  subjectId  String
  department String @default("general") // general / science / art / commercial

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
  @@index([schoolId])
  @@map("class_subjects")
}

// ---------------------------------------------------------------------------

model Subject {
  id       String  @id @default(cuid())
  schoolId String
  name     String
  code     String? // WAEC/NECO alignment, optional

  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments      Assignment[]
  questions        Question[]
  stimuli          Stimulus[]
  questionGroups   QuestionGroup[]
  syllabi          Syllabus[]
  lessonNotes      LessonNote[]
  exams            Exam[]
  subjectResults   SubjectResult[]
  timetableEntries TimetableEntry[]
  classSubjects    ClassSubject[]
  subjectRequirements  SubjectTimetableRequirement[]
  addonTimetableEntries AddonTimetableEntry[]
  taughtTopics          TaughtTopic[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

enum AssignmentType {
  subject_teacher
  class_teacher
  hod
  exam_officer
  school_admin
  fee_status_manager
}

// Assignment = scoped, versioned, many-to-many staff role.
// Effective permissions = union of all active assignments for current session/term.
model Assignment {
  id             String         @id @default(cuid())
  schoolId       String
  staffId        String
  assignmentType AssignmentType
  subjectId      String? // required for subject_teacher, hod
  classId        String? // required for subject_teacher, class_teacher
  sessionId      String?
  termId         String? // null = whole session
  isTemporary    Boolean        @default(false)
  startDate      DateTime?
  endDate        DateTime?
  createdBy      String?
  createdAt      DateTime       @default(now())

  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id])
  class   Class?   @relation(fields: [classId], references: [id])
  term    Term?    @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([staffId])
  @@index([sessionId])
  @@map("assignments")
}

// ---------------------------------------------------------------------------
// PRD 03: Student Management
// ---------------------------------------------------------------------------

enum StudentStatus {
  active
  withdrawn
  graduated
}

model Student {
  id              String        @id @default(cuid())
  schoolId        String
  admissionNumber String // unique per school, human-readable key
  firstName       String
  middleName      String?
  lastName        String
  email           String? // student email
  dateOfBirth     DateTime?
  ethnicity       String?
  religion        String?
  gender          String?
  passportPhoto   String?
  currentClassId  String?
  admissionDate   DateTime?
  status          StudentStatus @default(active)
  userId          String?       @unique // links to User for student login
  // Extended bio-data (blood_group, genotype, previous_school, etc.) — school-configurable
  bioData         Json?
  isClassCaptain  Boolean       @default(false)
  isViceClassCaptain Boolean   @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  currentClass   Class?          @relation(fields: [currentClassId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  guardians      Guardian[]
  subjectResults SubjectResult[]
  termResults    TermResult[]
  examAttempts   ExamAttempt[]
  consentRecords ConsentRecord[]
  taughtTopics   TaughtTopic[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([currentClassId])
  @@map("students")
}

model Guardian {
  id               String  @id @default(cuid())
  studentId        String
  relationship     String // father / mother / guardian / other
  fullName         String
  phone            String?
  email            String?
  address          String?
  isPrimaryContact Boolean @default(false)
  parentUserId     String? // links to User with role=parent

  student        Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  consentRecords ConsentRecord[]

  @@index([studentId])
  @@map("guardians")
}

// ---------------------------------------------------------------------------
// Authentication (platform-wide; supports Super Admin, staff, students, parents)
// ---------------------------------------------------------------------------

enum UserRole {
  super_admin
  platform_owner
  staff
  student
  parent
}

model User {
  id                 String   @id @default(cuid())
  schoolId           String? // null for super_admin (platform-level)
  email              String   @unique
  passwordHash       String
  role               UserRole
  staffId            String?  @unique // link when role = staff
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  school           School?         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff            Staff?          @relation(fields: [staffId], references: [id])
  student          Student?
  verifiedPayments Payment[]
  createdTickets   Ticket[]        @relation("TicketCreator")
  assignedTickets  Ticket[]        @relation("TicketAssignee")
  ticketMessages   TicketMessage[]

  @@index([schoolId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// PRD 11: Audit Logging (cross-cutting scaffold)
// ---------------------------------------------------------------------------

model AuditLog {
  id                     String   @id @default(cuid())
  schoolId               String?
  actorId                String? // staff/admin/user id
  actorAssignmentContext String? // which role/assignment they acted under
  action                 String // create / update / delete / approve / promote / etc.
  entityType             String // e.g. subject_result, question, student
  entityId               String?
  beforeValue            Json?
  afterValue             Json?
  timestamp              DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// PRD 11 — NDPR Compliance: Consent Record
// ---------------------------------------------------------------------------

model ConsentRecord {
  id            String   @id @default(cuid())
  studentId     String
  guardianId    String?
  consentType   String // e.g. "data_processing", "photo_use", "contact"
  consentedAt   DateTime @default(now())
  consentMethod String // "registration_form" / "csv_bulk" / "admin_input"
  schoolId      String?

  student  Student?  @relation(fields: [studentId], references: [id])
  guardian Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  school   School?   @relation(fields: [schoolId], references: [id])

  @@index([studentId])
  @@index([guardianId])
  @@map("consent_records")
}

// ---------------------------------------------------------------------------
// PRD 14: AI Provider Configuration (Super Admin only)
// ---------------------------------------------------------------------------

model AiProviderConfig {
  id               String   @id @default(cuid())
  label            String
  baseUrl          String
  apiKeyEncrypted  String // encrypted at rest, never returned plaintext
  defaultModelName String
  isActive         Boolean  @default(false)
  createdBy        String?
  createdAt        DateTime @default(now())

  taskProfiles AiTaskProfile[]
  callLogs     AiCallLog[]

  @@map("ai_provider_configs")
}

model AiTaskProfile {
  id                   String   @id @default(cuid())
  taskType             String // lesson_note_generation / question_generation / essay_grading / comment_drafting
  providerConfigId     String
  modelNameOverride    String?
  temperature          Float?   @default(0.7)
  maxTokens            Int?     @default(4096)
  systemPromptTemplate String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  provider AiProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([taskType, providerConfigId])
  @@map("ai_task_profiles")
}

model AiCallLog {
  id               String   @id @default(cuid())
  taskType         String
  schoolId         String?
  providerConfigId String?
  modelName        String
  promptTokens     Int?
  completionTokens Int?
  status           String // success / error / timeout
  errorDetail      String?
  latencyMs        Int?
  createdAt        DateTime @default(now())

  provider AiProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)

  @@index([taskType])
  @@index([schoolId])
  @@index([createdAt])
  @@map("ai_call_logs")
}

// ---------------------------------------------------------------------------
// PRD 04: Syllabus & Lesson Notes
// ---------------------------------------------------------------------------

model Syllabus {
  id           String   @id @default(cuid())
  schoolId     String
  subjectId    String
  classLevel   String // e.g. "JSS1", "SS2" — level-wide, not per-arm
  sessionId    String
  file         String? // uploaded document path/URL
  parsedTopics Json? // extracted/structured topic list
  createdAt    DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([schoolId, subjectId, classLevel, sessionId])
  @@index([schoolId])
  @@map("syllabi")
}

// ---------------------------------------------------------------------------
// CurriculumTopic — NERDC reference curriculum (pre-seeded) + school overrides
// ---------------------------------------------------------------------------

model CurriculumTopic {
  id                    String  @id @default(cuid())
  classLevel            String // JSS1 / JSS2 / JSS3 / SS1 / SS2 / SS3
  term                  String // FIRST / SECOND / THIRD
  subject               String // subject name (NERDC standard name)
  week                  Int
  weekSuffix            String  @default("") // "" for single-week, "A", "B", "C" for multi-week splits
  topic                 String
  subTopics             Json? // array of sub-topics / details
  behaviouralObjectives Json? // array of behavioural objective strings
  isSystem              Boolean @default(true) // true = NERDC default, false = school override
  schoolId              String? // null = NERDC defaults; set when a school overrides

  @@unique([classLevel, term, subject, week, weekSuffix, schoolId])
  @@index([classLevel, subject])
  @@map("curriculum_topics")
}

model NerdcContent {
  id        String   @id @default(cuid())
  content   String // raw markdown content of nerdc.md
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("nerdc_content")
}

model LessonNote {
  id                     String   @id @default(cuid())
  schoolId               String
  subjectId              String
  classId                String
  termId                 String
  syllabusId             String?
  topic                  String
  themeOrAspect          String? // theme / aspect of the syllabus
  duration               String? // e.g. "40 minutes"
  referenceBooks         String? // recommended textbooks
  instructionalMaterials String? // teaching aids
  // Structured lesson note sections
  previousKnowledge      String? // what students should already know
  introduction           String? // set induction / opening activity
  behaviouralObjectives  Json? // array of objective strings
  content                String? // students' note / board summary
  objectiveCoverageMap   String? // traceability: which parts of content cover which objective
  presentationSteps      Json? // array of {step_number, objective_reference, teacher_activity, student_activity}
  evaluation             String? // evaluation questions
  summary                String? // summary / conclusion
  assignment             String? // homework
  source                 String // manual / ai_generated
  status                 String   @default("draft") // draft / published
  createdBy              String // staff id
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([subjectId, classId, termId])
  @@map("lesson_notes")
}

// ---------------------------------------------------------------------------
// PRD 05: Question Bank & Exam Setup
// ---------------------------------------------------------------------------

model Stimulus {
  id        String  @id @default(cuid())
  type      String // passage / image / table / audio
  content   String
  subjectId String
  reusable  Boolean @default(false)

  subject Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  groups  QuestionGroup[]

  @@index([subjectId])
  @@map("stimuli")
}

model QuestionGroup {
  id                   String  @id @default(cuid())
  stimulusId           String?
  subjectId            String
  internallyShufflable Boolean @default(false)

  stimulus  Stimulus?  @relation(fields: [stimulusId], references: [id])
  subject   Subject    @relation(fields: [subjectId], references: [id])
  questions Question[]

  @@index([subjectId])
  @@map("question_groups")
}

enum QuestionType {
  mcq
  essay
}

enum QuestionStatus {
  draft
  pending_review
  approved
  archived
}

model Question {
  id              String         @id @default(cuid())
  schoolId        String
  subjectId       String
  classLevel      String?
  topic           String?
  type            QuestionType
  questionGroupId String?
  text            String
  marks           Float          @default(1)
  difficulty      String? // optional tag
  source          String // manual / csv_import / ai_generated
  status          QuestionStatus @default(draft)
  createdBy       String
  lessonNoteId    String? // provenance if AI-generated
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject        Subject           @relation(fields: [subjectId], references: [id])
  group          QuestionGroup?    @relation(fields: [questionGroupId], references: [id])
  mcqOptions     McqOption[]
  essaySpec      EssayGradingSpec?
  examQuestions  ExamQuestion[]
  studentAnswers StudentAnswer[]

  @@index([schoolId])
  @@index([subjectId, status])
  @@map("questions")
}

model McqOption {
  id         String  @id @default(cuid())
  questionId String
  optionText String
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("mcq_options")
}

model EssayGradingSpec {
  id            String  @id @default(cuid())
  questionId    String  @unique
  modelAnswer   String
  rubricPoints  Json // array of { description, mark }
  // AI grading prompt overrides, if any
  gradingPrompt String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("essay_grading_specs")
}

// ---------------------------------------------------------------------------
// PRD 06: Exam Delivery
// ---------------------------------------------------------------------------

enum ExamAttemptType {
  original
  resit
}

enum ExamStatus {
  draft
  published
}

model Exam {
  id                   String          @id @default(cuid())
  schoolId             String
  subjectId            String
  classId              String? // kept for backward compat; use ExamClass for multiple
  termId               String
  assessmentTypeId     String
  durationMinutes      Int
  shuffleEnabled       Boolean         @default(true)
  status               ExamStatus      @default(draft)
  attemptType          ExamAttemptType @default(original)
  originalExamId       String?
  // Per-exam sub-assessment weight distribution, e.g. [{ subAssessmentTypeId: "xxx", weightPercentage: 20 }]
  // Must sum to the parent assessment type's school-level weight.
  subAssessmentWeights Json?
  createdAt            DateTime        @default(now())

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id])
  class         Class?         @relation(fields: [classId], references: [id])
  term          Term           @relation(fields: [termId], references: [id])
  examQuestions ExamQuestion[]
  attempts      ExamAttempt[]
  classes       ExamClass[]

  @@index([schoolId])
  @@index([subjectId, classId, termId])
  @@map("exams")
}

model ExamClass {
  id      String @id @default(cuid())
  examId  String
  classId String

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id])

  @@unique([examId, classId])
  @@index([examId])
  @@index([classId])
  @@map("exam_classes")
}

model ExamQuestion {
  id         String @id @default(cuid())
  examId     String
  questionId String

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([examId])
  @@map("exam_questions")
}

enum AttemptStatus {
  in_progress
  submitted
  absent
  pending_resit
}

enum SyncStatus {
  local_only
  queued
  synced
}

model ExamAttempt {
  id                  String        @id @default(cuid())
  examId              String
  studentId           String
  startedAt           DateTime      @default(now())
  submittedAt         DateTime?
  status              AttemptStatus @default(in_progress)
  syncStatus          SyncStatus    @default(synced) // local_only for offline hub
  shuffledQuestionIds Json? // ordered array of question IDs for this student
  shuffledOptionOrder Json? // map of questionId → ordered option IDs
  endsAt              DateTime? // server-side timer end time (startedAt + durationMinutes)
  createdAt           DateTime      @default(now())

  exam    Exam            @relation(fields: [examId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])
  answers StudentAnswer[]

  @@index([examId])
  @@index([studentId])
  @@map("exam_attempts")
}

model StudentAnswer {
  id                  String   @id @default(cuid())
  attemptId           String
  questionId          String
  mcqSelectedOptionId String?
  essayResponseText   String?
  localChecksum       String?
  gradedScore         Float? // null until graded
  // AI essay grading fields (PRD 07)
  aiSuggestedScore    Float?
  aiReasoning         String?
  rubricPointMatches  Json?
  finalScore          Float? // null until teacher reviews
  gradedBy            String? // teacher id once reviewed
  gradingStatus       String   @default("ai_pending") // ai_pending / ai_complete / teacher_reviewed
  createdAt           DateTime @default(now())

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@index([attemptId])
  @@map("student_answers")
}

// ---------------------------------------------------------------------------
// PRD 08: Results, Grading & Report Cards
// ---------------------------------------------------------------------------

model AssessmentType {
  id        String   @id @default(cuid())
  schoolId  String
  name      String // e.g. "Mid Term Test"
  code      String   @default("") // e.g. "MDT" — short code used elsewhere (results, exams)
  parentId  String? // self-reference for sub-assessments
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parent   AssessmentType?  @relation("SubAssessments", fields: [parentId], references: [id])
  children AssessmentType[] @relation("SubAssessments")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("assessment_types")
}

model AssessmentWeighting {
  id               String  @id @default(cuid())
  schoolId         String
  subjectId        String?
  assessmentTypeId String // references AssessmentType.name (string, not FK for compatibility)
  weightPercentage Float

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, subjectId, assessmentTypeId])
  @@map("assessment_weightings")
}

model SubjectResult {
  id        String @id @default(cuid())
  studentId String
  subjectId String
  termId    String

  subject          Subject  @relation(fields: [subjectId], references: [id])
  student          Student  @relation(fields: [studentId], references: [id])
  term             Term     @relation(fields: [termId], references: [id])
  assessmentScores Json? // per assessment type: { raw, weight, weighted }
  totalScore       Float?
  grade            String?
  subjectPosition  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, subjectId, termId])
  @@index([termId])
  @@map("subject_results")
}

model TermResult {
  id        String @id @default(cuid())
  studentId String
  termId    String

  student           Student            @relation(fields: [studentId], references: [id])
  term              Term               @relation(fields: [termId], references: [id])
  verificationCodes VerificationCode[]

  overallAverage    Float?
  overallPosition   Int?
  attendanceSummary Json?
  affectiveRatings  Json? // school-configurable list
  teacherComment    String?
  principalComment  String?
  cumulativeAverage Float?
  status            String    @default("computed") // computed / finalised / withheld
  finalizedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([studentId, termId])
  @@index([termId])
  @@map("term_results")
}

model ReportCardTemplate {
  id           String   @id @default(cuid())
  schoolId     String
  appliesTo    String? // e.g. "junior", "senior", or class level
  layoutConfig Json? // which fields appear, ordering, branding
  sessionId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("report_card_templates")
}

// ---------------------------------------------------------------------------
// PRD 09: Result Verification Portal
// ---------------------------------------------------------------------------

model VerificationCode {
  id                String   @id @default(cuid())
  termResultId      String
  code              String   @unique
  status            String   @default("active") // active / revoked
  generatedAt       DateTime @default(now())
  regeneratedReason String?

  termResult TermResult @relation(fields: [termResultId], references: [id])

  @@index([code])
  @@index([termResultId])
  @@map("verification_codes")
}

// ---------------------------------------------------------------------------
// PRD 10: Timetable
// ---------------------------------------------------------------------------

model TimetablePeriod {
  id        String @id @default(cuid())
  schoolId  String
  name      String // e.g. "Period 1"
  startTime String // e.g. "08:00"
  endTime   String // e.g. "08:40"

  school  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  entries TimetableEntry[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("timetable_periods")
}

model TimetableEntry {
  id        String @id @default(cuid())
  schoolId  String
  classId   String
  periodId  String
  subjectId String
  staffId   String
  dayOfWeek Int // 0=Monday .. 4=Friday

  school  School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class           @relation(fields: [classId], references: [id])
  period  TimetablePeriod @relation(fields: [periodId], references: [id])
  subject Subject         @relation(fields: [subjectId], references: [id])
  staff   Staff           @relation(fields: [staffId], references: [id])

  @@unique([classId, periodId, dayOfWeek])
  @@index([classId, dayOfWeek])
  @@index([schoolId])
  @@map("timetable_entries")
}

// ---------------------------------------------------------------------------
// PRD 17: Timetable Generator Addon Models (addon-specific, gated behind addon check)
// ---------------------------------------------------------------------------

model SubjectTimetableRequirement {
  id                    String @id @default(cuid())
  schoolId              String
  subjectId             String
  classId               String? // null if applied level-wide
  classLevel            String? // e.g. "JSS1"
  weeklyPeriodsRequired Int
  doublePeriodAllowed   Boolean @default(true)
  preferredTimeOfDay    String @default("none") // morning / afternoon / none
  isPractical           Boolean @default(false)
  requiresRoomTypeId    String?

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("subject_timetable_requirements")
}

model StaffAvailability {
  id                 String  @id @default(cuid())
  schoolId           String
  staffId            String
  day                Int     // 0=Monday .. 4=Friday
  availablePeriodIds String[] // array of period IDs or names
  maxPeriodsPerDay   Int     @default(8)
  maxPeriodsPerWeek  Int     @default(40)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, day])
  @@map("staff_availability")
}

model TimetableTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  appliesTo String[] // e.g. ["JSS1", "JSS2"] or ["all"]

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolDays  SchoolDay[]
  periods     AddonPeriod[]
  timetables  AddonTimetable[]

  @@unique([schoolId, name])
  @@map("timetable_templates")
}

model SchoolDay {
  id            String  @id @default(cuid())
  templateId    String
  dayName       String  // e.g. "Monday"
  dayIndex      Int     // 0=Monday .. 4=Friday
  isTeachingDay Boolean @default(true)

  template TimetableTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("school_days")
}

model AddonPeriod {
  id           String @id @default(cuid())
  templateId   String
  periodNumber Int
  startTime    String // e.g. "08:00"
  endTime      String // e.g. "08:40"
  periodType   String // teaching / break / assembly / fixed_other

  template TimetableTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("addon_periods")
}

model SchoolTimetableRule {
  id         String  @id @default(cuid())
  schoolId   String
  ruleType   String  // max_consecutive_periods, max_subject_periods_per_day, fixed_period_assignment, room_exclusivity, subject_time_preference, max_teacher_subjects, practical_double_period, etc.
  parameters Json    // rule configuration parameters
  isHard     Boolean @default(true)
  weight     Int     @default(100)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_timetable_rules")
}

model RoomType {
  id       String @id @default(cuid())
  schoolId String
  name     String // e.g. "Physics Lab"
  rooms    Room[]

  @@map("room_types")
}

model Room {
  id         String @id @default(cuid())
  schoolId   String
  name       String // e.g. "Room 101"
  roomTypeId String
  capacity   Int    @default(40)

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@map("rooms")
}

model AddonTimetable {
  id              String   @id @default(cuid())
  schoolId        String
  sessionId       String
  termId          String
  templateId      String
  status          String   @default("draft") // draft / published / archived
  generatedAt     DateTime @default(now())
  generationScore Int      @default(0)

  school   School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  template TimetableTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  entries  AddonTimetableEntry[]
  runs     TimetableGenerationRun[]

  @@map("addon_timetables")
}

model AddonTimetableEntry {
  id          String  @id @default(cuid())
  timetableId String
  classId     String
  periodId    String  // references AddonPeriod
  day         Int     // 0=Monday .. 4=Friday
  subjectId   String
  staffId     String?
  roomId      String?
  isLocked    Boolean @default(false)

  timetable AddonTimetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  class     Class          @relation(fields: [classId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])
  staff     Staff?         @relation(fields: [staffId], references: [id])

  @@map("addon_timetable_entries")
}

model TimetableGenerationRun {
  id                       String    @id @default(cuid())
  timetableId              String
  triggeredBy              String
  startedAt                DateTime  @default(now())
  completedAt              DateTime?
  status                   String    // success / partial / failed
  finalScore               Int       @default(0)
  hardConstraintViolations String[]  // list of conflict descriptions
  iterationsRun            Int       @default(0)

  timetable AddonTimetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@map("timetable_generation_runs")
}
// ---------------------------------------------------------------------------

model FeeStatus {
  id        String   @id @default(cuid())
  studentId String
  termId    String
  status    String   @default("not_cleared") // cleared / not_cleared / partial
  setBy     String? // admin/bursar staff id
  notes     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([studentId, termId])
  @@index([termId])
  @@map("fee_statuses")
}

// ---------------------------------------------------------------------------
// PRD 13: Parent Portal & Notifications
// ---------------------------------------------------------------------------

model ParentAccount {
  id                      String   @id @default(cuid())
  guardianId              String // links to Guardian entity (PRD 03)
  email                   String
  passwordHash            String
  phone                   String?
  notificationPreferences Json? // which channels/events
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([email])
  @@index([guardianId])
  @@map("parent_accounts")
}

model Notification {
  id             String    @id @default(cuid())
  schoolId       String?
  recipientType  String // parent / staff
  recipientId    String
  channel        String // sms / push / in_app / email
  eventType      String // result_published / fee_status_changed / general_notice / exam_graded
  title          String?
  content        String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  sentAt         DateTime  @default(now())
  deliveryStatus String    @default("pending") // pending / sent / failed / read

  @@index([recipientType, recipientId])
  @@map("notifications")
}

model Announcement {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  content     String
  targetRoles String[] // ["student", "staff", "parent"]
  isSticky    Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("announcements")
}

enum LicenseDurationType {
  monthly
  termly
}

model LicensePlan {
  id           String              @id @default(cuid())
  name         String              @unique // e.g. "Monthly", "Termly"
  durationType LicenseDurationType
  price        Decimal? // e.g. 50000.00
  durationDays Int? // e.g. 30 or 90
  isActive     Boolean             @default(true) // can this plan be assigned to new schools?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  stages         PlanStage[]
  schoolLicenses SchoolLicense[]
  payments       Payment[]
  cashCodes      CashCode[]

  @@map("license_plans")
}

// Configurable pricing stage within a plan (e.g. tiered pricing by school size)
model PlanStage {
  id        String   @id @default(cuid())
  planId    String
  name      String   // e.g. "Basic (1-100)", "Standard (101-500)", "Premium (501+)"
  price     Decimal? // overrides plan price; null = use plan default
  criteria  Json?    // optional: e.g. {"minStudents": 1, "maxStudents": 100}
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan             LicensePlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  schools          School[]
  licenseSnapshots SchoolLicense[]

  @@index([planId])
  @@map("plan_stages")
}

enum LicenseStatus {
  active
  grace_period
  expired
  suspended
}

model SchoolLicense {
  id               String        @id @default(cuid())
  schoolId         String
  planId           String
  stageId          String? // snapshot of the stage at time of license creation
  startDate        DateTime
  endDate          DateTime
  status           LicenseStatus @default(active)
  paymentReference String? // free-text record of how/when the school paid
  setBy            String? // Platform Owner user id
  autoRenewIntent  Boolean       @default(false) // informational only
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  school School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan   LicensePlan @relation(fields: [planId], references: [id])
  stage  PlanStage?  @relation(fields: [stageId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@map("school_licenses")
}

// ---------------------------------------------------------------------------
// PRD X: Payment Methods & Payments
// ---------------------------------------------------------------------------

enum PaymentMethodType {
  bank_transfer
  cash
  online
}

model PaymentMethod {
  id        String            @id @default(cuid())
  type      PaymentMethodType
  label     String // display name e.g. "GTBank", "Cash", "Paystack"
  isActive  Boolean           @default(true)
  details   Json? // bank_transfer: {bankName, accountNumber, accountName, instructions} / online: {provider, publicKey} / cash: null
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  payments Payment[]

  @@map("payment_methods")
}

model CashCode {
  id             String    @id @default(cuid())
  code           String    @unique // e.g. "CASH-A3B7K9"
  planId         String
  schoolId       String? // pre-assigned to a school (optional)
  isUsed         Boolean   @default(false)
  usedAt         DateTime?
  usedBySchoolId String?
  createdAt      DateTime  @default(now())

  plan LicensePlan @relation(fields: [planId], references: [id])

  @@index([code])
  @@map("cash_codes")
}

model Addon {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  features     Json?   // array of feature descriptions
  price        Decimal? // null = free
  durationDays Int?    // null = one-time/permanent, set = renewable
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolAddons    SchoolAddon[]
  activationCodes AddonCode[]

  @@map("addons")
}

model AddonCode {
  id             String    @id @default(cuid())
  code           String    @unique // e.g. "ADDON-A3B7K9"
  addonId        String
  schoolId       String?   // pre-assigned to a school (optional)
  isUsed         Boolean   @default(false)
  usedAt         DateTime?
  usedBySchoolId String?
  createdAt      DateTime  @default(now())

  addon Addon @relation(fields: [addonId], references: [id])

  @@index([code])
  @@map("addon_codes")
}

model SchoolAddon {
  id             String    @id @default(cuid())
  schoolId       String
  addonId        String
  status         String    @default("active") // active, expired, suspended
  activatedAt    DateTime  @default(now())
  expiresAt      DateTime? // null = permanent
  activatedVia   String    // "purchase" or "code"
  activationCode String?   // the code used (if via code)
  paymentId      String?   // the payment (if via purchase)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id])

  @@unique([schoolId, addonId])
  @@index([schoolId])
  @@map("school_addons")
}

model Payment {
  id              String    @id @default(cuid())
  schoolId        String
  planId          String
  amount          Decimal
  paymentMethodId String
  status          String    @default("pending") // pending, verified, failed, refunded
  cashCodeId      String? // links to the cash code used (for cash payments)
  reference       String? // user-entered ref (bank transfer) or gateway ref (online)
  proofUrl        String? // uploaded receipt image for bank transfer
  notes           String?
  verifiedById    String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan          LicensePlan   @relation(fields: [planId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  verifiedBy    User?         @relation(fields: [verifiedById], references: [id])

  @@index([schoolId])
  @@index([status])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Support Tickets
// ---------------------------------------------------------------------------

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

model Ticket {
  id           String         @id @default(cuid())
  schoolId     String
  title        String
  description  String
  status       TicketStatus   @default(open)
  priority     TicketPriority @default(medium)
  category     String? // e.g. "billing", "technical", "feature_request", "other"
  createdById  String
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  messages   TicketMessage[]

  @@index([schoolId])
  @@index([status])
  @@index([createdById])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

// ---------------------------------------------------------------------------
// PRD 18: Period Tracker Addon — track curriculum coverage by teachers
// ---------------------------------------------------------------------------

model TaughtTopic {
  id                String    @id @default(cuid())
  schoolId          String
  classId           String
  subjectId         String
  curriculumTopicId String?
  termId            String?
  teacherId         String    // Staff id
  teacherMarked     Boolean   @default(false)
  captainMarked     Boolean   @default(false)
  studentId         String?   // Student (captain/vice) who marked
  teacherMarkedAt   DateTime?
  captainMarkedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    Class     @relation(fields: [classId], references: [id])
  subject  Subject   @relation(fields: [subjectId], references: [id])
  teacher  Staff     @relation(fields: [teacherId], references: [id])
  student  Student?  @relation(fields: [studentId], references: [id])

  @@unique([classId, subjectId, curriculumTopicId, teacherId])
  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@map("taught_topics")
}
